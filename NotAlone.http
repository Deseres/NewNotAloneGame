@NotAlone_HostAddress = http://localhost:5000

### Register a new user
POST {{NotAlone_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "email": "player1@example.com",
  "password": "Password123"
}

###

### Login to get JWT token
POST {{NotAlone_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "player1@example.com",
  "password": "Password123"
}

@token = YOUR_TOKEN_HERE

###

### Start a new game (requires authentication)
POST {{NotAlone_HostAddress}}/api/game/start
Authorization: Bearer {{token}}
Content-Type: application/json

###
